# --- Dependencies (regenerated by npm install) ---
node_modules/
**/node_modules/

# --- Python bytecode / caches ---
__pycache__/
**/__pycache__/
*.py[cod]
*.egg-info/
.eggs/

# --- Virtualenvs ---
.venv/
venv/
env/

# --- Frontend build output ---
capsule-web/dist/
**/.vite/
*.tsbuildinfo

# --- Logs & local test artifacts ---
# (Playwright screenshots/zips are written to /tmp, not the tree, so no blanket
#  image ignore here — that would drop real UI assets like logos/favicons.)
*.log
test-results/
playwright-report/

# --- OS / editor cruft ---
.DS_Store
Thumbs.db
.idea/
*.swp

# NOTE: dev-only .env files (docker/.env, capsule-web/.env) are intentionally
# committed so the stack runs out-of-the-box. They contain no production secrets.
