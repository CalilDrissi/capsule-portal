# Caddy config: one domain, SPA + Mayan API same-origin, automatic HTTPS.
# Domain and ACME email are injected from deploy/.env.prod via the caddy service.

{
	email {$CAPSULE_ACME_EMAIL}
}

{$CAPSULE_DOMAIN} {
	encode zstd gzip

	# SPA static root (mounted from capsule-web/dist).
	root * /srv/spa

	# Everything the Mayan backend must serve goes to app:8000.
	#   /api      -> REST API (SPA uses /api/v4; document up/download live here too)
	#   /static   -> Django/Mayan static assets (needed by /admin and any Mayan page)
	#   /media    -> user media served by Django, if enabled
	#   /admin    -> Django admin (platform superuser only; drop this line to hide it)
	#   /favicon.ico -> Mayan favicon
	@backend path /api* /static* /media* /admin* /favicon.ico
	handle @backend {
		# Caddy sets X-Forwarded-Proto=https and preserves the Host header,
		# which satisfies MAYAN_SECURE_PROXY_SSL_HEADER / USE_X_FORWARDED_HOST /
		# ALLOWED_HOSTS.
		reverse_proxy app:8000
	}

	# Everything else is the SPA. Fall back to index.html for client-side routes.
	handle {
		try_files {path} /index.html
		file_server
	}
}
