##############################################################################
# Capsule production environment — TEMPLATE.
#
#   cp deploy/.env.prod.example deploy/.env.prod   then fill EVERY value below.
#
# This file is used TWICE by the up command:
#   1. `--env-file deploy/.env.prod`  -> variable interpolation in the compose
#      files (datastore passwords baked into MAYAN_DATABASES / broker URLs, the
#      Caddy domain + ACME email).
#   2. loaded into the app container as an env_file -> Mayan reads the MAYAN_*
#      settings below (SECRET_KEY, ALLOWED_HOSTS, CORS, proxy/CSRF).
#
# List values (MAYAN_ALLOWED_HOSTS etc.) are YAML/JSON flow lists — keep the
# brackets and quotes exactly as shown.
#
# Generate secrets:
#   Secret key:      openssl rand -base64 50
#   A password:      openssl rand -hex 32
##############################################################################

# ===== Caddy / TLS =====================================================
# The single public domain. DNS A record must point at this server first.
CAPSULE_DOMAIN=your.domain.com
# Email Let's Encrypt uses for cert-expiry notices.
CAPSULE_ACME_EMAIL=admin@your.domain.com

# ===== Mayan core ======================================================
# Django secret key — REQUIRED, set explicitly and never rotate casually.
#   openssl rand -base64 50
MAYAN_SECRET_KEY=CHANGE_ME_openssl_rand_base64_50

# Hosts Django will serve. Must include your domain (JSON list).
MAYAN_ALLOWED_HOSTS=["your.domain.com"]

# CORS: SPA is same-origin, so lock CORS down.
MAYAN_CORS_ORIGIN_ALLOW_ALL=false
MAYAN_CORS_ALLOWED_ORIGINS=["https://your.domain.com"]

# Trust the X-Forwarded-Proto header Caddy sets so Django knows it's HTTPS.
MAYAN_SECURE_PROXY_SSL_HEADER=["HTTP_X_FORWARDED_PROTO","https"]
MAYAN_USE_X_FORWARDED_HOST=true

# CSRF trusted origins (scheme + host) for the Django admin / session views.
MAYAN_CSRF_TRUSTED_ORIGINS=["https://your.domain.com"]

# ===== Datastore passwords (STRONG, unique) ============================
# Used both for interpolation (DB URL / broker URLs / requirepass) and the
# respective service containers. Set BEFORE the first `up` — changing them
# after the volumes are initialized requires manual DB/broker password changes.
#   openssl rand -hex 32
MAYAN_DATABASE_PASSWORD=CHANGE_ME_openssl_rand_hex_32
MAYAN_RABBITMQ_PASSWORD=CHANGE_ME_openssl_rand_hex_32
MAYAN_REDIS_PASSWORD=CHANGE_ME_openssl_rand_hex_32

# Only needed if you also enable the `elasticsearch` profile (default search
# backend works without it). Safe to leave as-is otherwise.
MAYAN_ELASTICSEARCH_PASSWORD=CHANGE_ME_openssl_rand_hex_32

# ===== Optional overrides ==============================================
# Database name/user default to `mayan` (see base compose). Uncomment to change.
# MAYAN_DATABASE_NAME=mayan
# MAYAN_DATABASE_USER=mayan
# MAYAN_RABBITMQ_USER=mayan
# MAYAN_RABBITMQ_VHOST=mayan
